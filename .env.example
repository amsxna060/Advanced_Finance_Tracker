# ─── Database ───────────────────────────────────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=change-this-strong-db-password
DATABASE_URL=postgresql://admin:change-this-strong-db-password@localhost:5432/finance_tracker  # REQUIRED

# ─── JWT ────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-this-in-production  # REQUIRED
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Gold Price API ─────────────────────────────────────────
GOLD_API_URL=https://goldpricez.com/api/rates/currency/inr/measure/gram
GOLD_CACHE_TTL_SECONDS=3600

# ─── Lending ────────────────────────────────────────────────
# Interest-only loans: how many future months of interest a borrower may prepay
# before any excess is treated as a principal reduction. Protects principal when
# a borrower simply pays next month's interest in advance. 0 disables the buffer.
LOAN_INTEREST_PREPAY_MONTHS=2

# ─── Seed Admin (created on first startup if no users exist) ─
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=change-this-strong-password  # REQUIRED
SEED_ADMIN_EMAIL=admin@finance.local

# ─── App ────────────────────────────────────────────────────
# Set to "production" on Render/cloud — enables security validators
APP_ENV=development
CORS_ORIGINS=http://localhost:5173

# ─── AI Chatbot (Google Gemini) ─────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-from-aistudio-google-com
GEMINI_MODEL=gemini-2.5-flash

# ── SaaS migration (Phase 1/2) ──────────────────────────────────────────
# Public signup master switch (default false — enable only after the
# security review in docs/saas-migration/SECURITY_REVIEW_SIGNUP.md)
SIGNUP_ENABLED=true
REQUIRE_EMAIL_VERIFICATION=false
EMAIL_BACKEND=console            # console | smtp
#SMTP_HOST=smtp.gmail.com
#SMTP_PORT=587
#SMTP_USER=
#SMTP_PASSWORD=
#EMAIL_FROM="FinancerBuddy <no-reply@financerbuddy.com>"
FRONTEND_URL=http://localhost:5173
# Cut-over: create the read-only platform admin + demote legacy admins
#PLATFORM_ADMIN_USERNAME=fbadmin
#PLATFORM_ADMIN_EMAIL=admin@financerbuddy.com
#PLATFORM_ADMIN_PASSWORD=<12+ chars>
#PLATFORM_ADMIN_READ_ONLY=true
#DEMOTE_OTHER_ADMINS=true
# Async backbone (E7): empty = no Redis needed (tasks run in-process)
#REDIS_URL=redis://localhost:6379/0
